<?xml version='1.0' encoding='UTF-8'?>

<!-- Example for HomeAutomation ! -->

<models>
    <properties>
        <property modelName='model_p_state_onoff' propertyId='state' propertyClass='load_property'/>
        <property modelName='model_p_heating_mode' propertyId='heating_mode' propertyClass='load_property'/>
        <property modelName='model_p_heating_meas_val' propertyId='heating_m_value' propertyClass='load_property'/>
        <property modelName='model_p_heating_unit_val' propertyId='heating_u_value' propertyClass='load_property'/>
        <property modelName='model_p_rocker1' propertyId='rocker1' propertyClass='sensor_property'/>
        <property modelName='model_p_rocker2' propertyId='rocker2' propertyClass='sensor_property'/>
        <property modelName='model_p_temperature' propertyId='temperature' propertyClass='sensor_property'/>
        <property modelName='model_p_humidity' propertyId='humidity' propertyClass='sensor_property'/>
        <property modelName='model_p_state_openclosed' propertyId='closed' propertyClass='sensor_property'/>
        <property modelName='model_p_binary_output1' propertyId='output1' propertyClass='actuator_property'/>
        <property modelName='model_p_binary_output2' propertyId='output2' propertyClass='actuator_property'/>
        <property modelName='model_p_pw_mode' propertyId='pw_mode' propertyClass='actuator_property'/>
        <property modelName='model_p_meas_val' propertyId='m_value' propertyClass='actuator_property'/>
        <property modelName='model_p_unit_val' propertyId='u_value' propertyClass='actuator_property'/>
    </properties>
    <processors>
        <processor modelName='synchronize_actuator' commandName='synchronize' processorClass='actuator_command_processor' />
        <processor modelName='set_actuator' commandName='set' processorClass='actuator_command_processor' />
        <processor modelName='energy_actuator' commandName='energy' processorClass='actuator_command_processor' />
        <processor modelName='power_actuator' commandName='power' processorClass='actuator_command_processor' />
        <processor modelName='synchronize_load' commandName='synchronize' processorClass='load_command_processor' />
        <processor modelName='set_load' commandName='set' processorClass='load_command_processor' />
        <processor modelName='energy_load' commandName='energy' processorClass='load_command_processor' />
        <processor modelName='power_load' commandName='power' processorClass='load_command_processor' />
    </processors>
    <observables>

        <observable modelName='rocker_switch_2_buttons' observableClass='sensor'>
            <propertyModelRefs>
                <propertyModelRef modelName='model_p_rocker1'/>
                <propertyModelRef modelName='model_p_rocker2'/>
            </propertyModelRefs>
            <processorModelRefs>
            </processorModelRefs>
        </observable>

        <observable modelName='temperature_humidity_sensor' observableClass='sensor'>
            <propertyModelRefs>
                <propertyModelRef modelName='model_p_temperature'/>
                <propertyModelRef modelName='model_p_humidity'/>
            </propertyModelRefs>
            <processorModelRefs>
            </processorModelRefs>
        </observable>

        <observable modelName='window_sensor' observableClass='sensor'>
            <propertyModelRefs>
                <propertyModelRef modelName='model_p_state_openclosed'/>
            </propertyModelRefs>
            <processorModelRefs>
            </processorModelRefs>
        </observable>

        <observable modelName='actuator_2_outputs_binary' observableClass='actuator'>
            <propertyModelRefs>
                <propertyModelRef modelName='model_p_binary_output1'/>
                <propertyModelRef modelName='model_p_binary_output2'/>
            </propertyModelRefs>
            <processorModelRefs>
                <processorModelRef modelName='synchronize_actuator'/>
                <processorModelRef modelName='set_actuator'/>
            </processorModelRefs>
        </observable>

        <observable modelName='pw_actuator' observableClass='actuator'>
            <propertyModelRefs>
                <propertyModelRef modelName='model_p_pw_mode'/>
            </propertyModelRefs>
            <processorModelRefs>
                <processorModelRef modelName='synchronize_actuator'/>
                <processorModelRef modelName='set_actuator'/>
            </processorModelRefs>
        </observable>

        <observable modelName='pw_actuator_measurement' observableClass='actuator'>
            <propertyModelRefs>
                <propertyModelRef modelName='model_p_pw_mode'/>
                <propertyModelRef modelName='model_p_meas_val'/>
                <propertyModelRef modelName='model_p_unit_val'/>
            </propertyModelRefs>
            <processorModelRefs>
                <processorModelRef modelName='synchronize_actuator'/>
                <processorModelRef modelName='set_actuator'/>
                <processorModelRef modelName='energy_actuator'/>
                <processorModelRef modelName='power_actuator'/>
            </processorModelRefs>
        </observable>

        <observable modelName='onoff_smart_plug_measurement' observableClass='actuator'>
            <propertyModelRefs>
                <propertyModelRef modelName='model_p_binary_output1'/>
                <propertyModelRef modelName='model_p_meas_val'/>
                <propertyModelRef modelName='model_p_unit_val'/>
            </propertyModelRefs>
            <processorModelRefs>
                <processorModelRef modelName='synchronize_actuator'/>
                <processorModelRef modelName='set_actuator'/>
                <processorModelRef modelName='energy_actuator'/>
                <processorModelRef modelName='power_actuator'/>
            </processorModelRefs>
        </observable>

        <observable modelName='onoff_lighting' observableClass='load'>
            <propertyModelRefs>
                <propertyModelRef modelName='model_p_state_onoff'/>
            </propertyModelRefs>
            <processorModelRefs>
                <processorModelRef modelName='synchronize_load'/>
                <processorModelRef modelName='set_load'/>
            </processorModelRefs>
        </observable>

        <observable modelName='pw_electric_heating' observableClass='load'>
            <propertyModelRefs>
                <propertyModelRef modelName='model_p_heating_mode'/>
            </propertyModelRefs>
            <processorModelRefs>
                <processorModelRef modelName='synchronize_load'/>
                <processorModelRef modelName='set_load'/>
            </processorModelRefs>
        </observable>

        <observable modelName='pw_electric_heating_measurement' observableClass='load'>
            <propertyModelRefs>
                <propertyModelRef modelName='model_p_heating_mode'/>
                <propertyModelRef modelName='model_p_heating_meas_val'/>
                <propertyModelRef modelName='model_p_heating_unit_val'/>
            </propertyModelRefs>
            <processorModelRefs>
                <processorModelRef modelName='synchronize_load'/>
                <processorModelRef modelName='set_load'/>
                <processorModelRef modelName='energy_load'/>
                <processorModelRef modelName='power_load'/>
            </processorModelRefs>
        </observable>

    </observables>
</models>
