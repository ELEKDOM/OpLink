              <channels>
                <channel idx="channel number" name="associated property"/>
                ...
                ...
              </channels>
              <outputs>
                <output actuator-property="actuator's property id" load="observable name"  actuated-property="load's property id"/>
                ...
                ...
              </outputs>
            </actuator>
            ...
            ...
          </actuators>
          <sensors>
            <sensor name="observable name" observable-model-name="model name" id="device id" device-model="device model name" localisation="location name">
            <channels>
              <channel idx="channel number" name="associated property"/>
              ...
              ...
            </channels>
            </sensor>
            ...
            ...
          </sensors>
        </observables>
    </area> 
    ...
    ...
  </areas>
