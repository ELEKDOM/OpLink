<?xml version="1.0" encoding="UTF-8"?>

<!-- Configuration file template. Do not use this file directly for deployment.
Create a directory containing all the configuration files for a given deployment ! -->

<!-- The heating manager is a virtual device whose role is to control the temperature of a group of rooms.
This file defined the declaration for a radiator management area of type pilotwire.
-->
<heating-manager name="" localisation="" title="" control="pw" state="">
    <pw-control setpoint="scheduled" >
    <!-- <pw-control> tag for a "pilote wire control" -->
    <!-- setpoint : defines a fixed or scheduled setpoint. If the value is "scheduled", a scheduler must be declared.
                    Otherwise, a pilotwire order defines the target to be reached. -->

        <scheduler>
            <daily-schedulers>
                <daily-scheduler name="">
                    <scheduled-event time="" evt="" />
                    <!-- evt = value to emit, string as pilot wire order:
                        on, off, comfort, comfort_1, comfort_2, eco, nofrost
                    -->
                    <scheduled-event time="" evt="" />
                </daily-scheduler>
                <daily-scheduler name="">
                    <scheduled-event time="" evt="" />
                    <scheduled-event time="" evt="" />
                </daily-scheduler>
            </daily-schedulers>
            <weekly-schedulers>
                <weekly-scheduler name="" assigned-weeks="">
                    <daily-sequence name="" assigned-days=""/>
                    <daily-sequence name="" assigned-days=""/>
                </weekly-scheduler>
            </weekly-schedulers>
        </scheduler>
    </pw-control>
    <rooms>
        <room name="" window-opening-detection="yes">
            <heaters>
                <heater-ref name="" property=""/>
            </heaters>
            <window-sensors>
                <window-sensor-ref name="" property=""/>
            </window-sensors>
            <temp-sensors>
                <temp-sensor-ref name="" property=""/>
            </temp-sensors>
        </room>
    </rooms>
</heating-manager>
